# ===== CDMS NAS Worker 환경설정 (.env) =====
# 이 파일을 복사해서 .env 로 만들고 값을 채우세요.  실제 .env 는 절대 깃/프런트에 올리지 마세요.

# Supabase
SUPABASE_URL=https://kowtvvrgpzgrdlnxasxw.supabase.co
# ⚠️ service_role 키 (서버 전용, 비공개). Supabase 대시보드 > Project Settings > API 에서 복사.
#    이 키는 RLS를 우회하므로 index.html 등 클라이언트에는 절대 넣지 마세요.
SUPABASE_SERVICE_ROLE_KEY=여기에_service_role_키

# NAS 접근 방식:  mount (서버에 마운트됨)  또는  smb (직접 접속)
NAS_MODE=mount

# --- mount 모드 ---
# NAS가 서버에 마운트된 경로. 과정 폴더(nas_root)는 이 아래에 생성/탐색됩니다.
NAS_BASE=/mnt/nas

# --- smb 모드 (NAS_MODE=smb 일 때만) ---
# 비워두면 Supabase nas_config 테이블 값을 사용합니다.
NAS_SMB_HOST=192.168.0.48
NAS_SMB_USER=
NAS_SMB_PASS=
NAS_SMB_SHARE=

# 영상길이 기준 단계 (종편=7). 변경 불필요.
LENGTH_STAGE_ID=7

# 자동 전체스캔 주기(초). 0 이면 끔(UI 버튼/큐 작업만 처리). 기본 600(10분).
SCAN_INTERVAL=600
# 큐 폴링 주기(초)
POLL_INTERVAL=3

# ===== 자동 이메일 (단계 완료 → 다음 담당자) =====
EMAIL_ENABLED=true
# resend 또는 sendgrid
EMAIL_PROVIDER=resend
# Resend: re_xxx / SendGrid: SG.xxx
EMAIL_API_KEY=여기에_이메일_API_키
# 발신자. 도메인 인증이 된 주소를 권장(미인증 시 발송 실패/스팸 가능)
EMAIL_FROM=CDMS <noreply@mirimmedialab.co.kr>
# 메일 본문에 들어갈 CDMS 주소
CDMS_URL=https://cdms.mirimmedialab.co.kr
# 계약만료 등 알림메일에서 PM 이메일이 임시값/미설정일 때 보낼 폴백 주소
REMIND_EMAIL=ghnam7312@gmail.com

# ===== 영상검수: 시놀로지(외부 HTTPS) 직접 서빙 =====
# 아래를 채우면 검수영상을 Supabase 업로드 대신 시놀로지 공개 URL로 사용합니다(변환 없음).
# 비워두면 기존 방식(480p 프록시 → Supabase)으로 동작.
# NAS_PUBLIC_ROOT: Web Station 문서루트에 매핑되는 로컬 경로 (예: /mnt 또는 /mnt/kepco)
# NAS_PUBLIC_BASE: 그 루트의 공개 HTTPS 베이스 URL (반드시 https, QuickConnect/DDNS)
NAS_PUBLIC_ROOT=/mnt
NAS_PUBLIC_BASE=

# ===== 매출 동기화(sales_sync.py) =====
# 구글시트 '2026년도 매출 현황'의 '2026년' 탭을 '웹에 게시(CSV)' 한 링크
SALES_CSV_URL=
